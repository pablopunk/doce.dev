---
import { SettingsWorkspace } from "@/components/settings/SettingsWorkspace";
import AppLayout from "@/layouts/AppLayout.astro";
import { getProjectsByUserId } from "@/server/projects/projects.model";
import {
	getQueueStatusPageData,
	getSettingsStatusDiagnostics,
} from "@/server/settings/status";

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect("/login");
}

const projects = await getProjectsByUserId(user.id);
const projectCount = projects.length;
const tabParam = Astro.url.searchParams.get("tab");
// Legacy tab IDs redirect to "general"
const legacyTabs = ["status", "base-url", "account", "danger"];
const initialTab =
	tabParam === "mcps" || tabParam === "skills" || tabParam === "general"
		? tabParam
		: legacyTabs.includes(tabParam ?? "")
			? "general"
			: "providers";

const queueFilters: import("@/server/settings/status").QueueStatusFilters = {};
const stateParam = Astro.url.searchParams.get("state");
const typeParam = Astro.url.searchParams.get("type");
const projectIdParam = Astro.url.searchParams.get("projectId");
const qParam = Astro.url.searchParams.get("q");
const pageParam = Astro.url.searchParams.get("page");

if (stateParam) queueFilters.state = stateParam;
if (typeParam) queueFilters.type = typeParam;
if (projectIdParam) queueFilters.projectId = projectIdParam;
if (qParam) queueFilters.q = qParam;
if (pageParam) queueFilters.page = pageParam;

const statusData = await getQueueStatusPageData(queueFilters);
const diagnostics = await getSettingsStatusDiagnostics();
---

<AppLayout title="Settings">
	<main class="container mx-auto max-w-6xl p-4 md:p-8">
		<div class="mb-6 md:mb-8 flex items-center justify-between">
			<div>
				<h1 class="text-2xl md:text-3xl font-bold">Settings</h1>
				<p class="text-muted-foreground text-sm md:text-base">Manage your doce.dev configuration</p>
			</div>
		</div>

		<SettingsWorkspace
			projectCount={projectCount}
			initialTab={initialTab}
			statusData={{ ...statusData, diagnostics }}
			client:load
		/>
	</main>
</AppLayout>
