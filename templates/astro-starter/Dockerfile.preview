ARG PREVIEW_BASE_IMAGE=node:22-slim
FROM ${PREVIEW_BASE_IMAGE}

RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.20.0 --activate

WORKDIR /app

EXPOSE 4321

HEALTHCHECK --interval=5s --timeout=5s --retries=10 --start-period=30s \
    CMD curl -fsS http://localhost:4321 >/dev/null || exit 1

CMD ["/bin/sh", "/app/scripts/start-preview-dev.sh"]
